#!/usr/bin/env bash

SSH_CMD="ssh -D 1081 -N -C -f -p 443 dmitry@45.151.68.245"
DISABLED_FLAG="/tmp/ssh-tunnel-disabled"

is_running() {
    pgrep -f "ssh -D 1081.*45.151.68.245" > /dev/null 2>&1
}

start_tunnel() {
    $SSH_CMD
}

# Auto-reconnect if not disabled
if ! is_running && [ ! -f "$DISABLED_FLAG" ]; then
    start_tunnel
fi

# Output JSON for waybar
if is_running; then
    echo '{"text":"󰒄 :1081","alt":"connected","class":"connected","tooltip":"SSH tunnel active on port 1081"}'
else
    echo '{"text":"󰒃 :1081","alt":"disconnected","class":"disconnected","tooltip":"SSH tunnel inactive"}'
fi
